      </geometry>
    </visual>
    <inertial>
      <mass value="${depth_camera_mass}" />
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${depth_camera_ixx}" ixy="${depth_camera_ixy}" ixz="${depth_camera_ixz}" iyy="${depth_camera_iyy}" iyz="${depth_camera_iyz}" izz="${depth_camera_izz}" />
    </inertial>
  </link>
  <joint name="camera_optical_joint_right" type="fixed">
    <origin xyz="0 0 0" rpy="${-PI/2} 0 ${-PI/2}"/>
    <parent link="camera_right"/>
    <child link="camera_optical_right"/>
  </joint>
  <link name="camera_optical_right">
  </link>

  <!-- 后下相机 -->
  <joint name="camera_joint_rearDown" type="fixed">
