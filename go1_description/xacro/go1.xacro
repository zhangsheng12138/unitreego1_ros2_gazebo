  </joint>
  <link name="camera_optical_left">
  </link>

  <!-- 右相机 -->
  <joint name="camera_joint_right" type="fixed">
    <origin rpy="${PI} 0.2618 ${-PI/2}" xyz="${depth_camera_right}"/>
