    <child link="RR_thigh"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="${thigh_damping}" friction="${thigh_friction}"/>
    <limit effort="${thigh_effort_limit}" lower="${thigh_lower_limit}" upper="${thigh_upper_limit}" velocity="${thigh_velocity_limit}"/>
  </joint>
  <link name="RR_thigh">
    <inertial>
      <mass value="${thigh_mass}"/>
      <inertia ixx="${thigh_ixx}" ixy="${thigh_ixy}" ixz="${thigh_ixz}" iyy="${thigh_iyy}" iyz="${thigh_iyz}" izz="${thigh_izz}"/>
    </inertial>
