<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    ROS2 Compatible Go1 Robot URDF                                                | -->
<!-- |    Gazebo Harmonic + ros2_control                                               | -->
<!-- |    完整无省略版 - Unitree Go1 四足机器人                                       | -->
<!-- =================================================================================== -->
<robot name="go1" xmlns:xacro="http://wiki.ros.org/xacro">
  
  <!-- 包含参数文件 -->
  <xacro:include filename="$(find go1_description)/xacro/go1_urdf_parameter.xacro" />
  
  <!-- 常量定义 -->
  <!-- PI is already defined in the parameter file -->
  
  <!-- ===================== 基础材料定义 ===================== -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.9137 0.9137 0.8471 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>
  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- ===================== ROS2 CONTROL 核心插件 ===================== -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find go1_description)/config/robot_control.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ===================== 外力施加插件 (ROS2) ===================== -->
  <gazebo>
    <plugin filename="libgazebo_ros_force.so" name="gazebo_ros_force">
      <body_name>trunk</body_name>
      <topic_name>${topic_force}</topic_name>
      <ros2>true</ros2>
    </plugin>
  </gazebo>

  <!-- ===================== IMU 传感器 (ROS2) ===================== -->
  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>${imu_update_rate}</update_rate>
      <visualize>${imu_visualize}</visualize>
      <plugin filename="libgazebo_ros2_imu.so" name="imu_plugin">
        <frame_id>imu_link</frame_id>
        <topic_name>${topic_imu}</topic_name>
        <update_rate>${imu_update_rate}.0</update_rate>
        <angular_velocity_stdev>0.0</angular_velocity_stdev>
        <linear_acceleration_stdev>0.0</linear_acceleration_stdev>
        <orientation_stdev>0.0</orientation_stdev>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>

  <!-- ===================== 深度相机 (ROS2) ===================== -->
  <gazebo reference="camera_face">
    <sensor name="camera_face_camera" type="depth">
      <update_rate>${camera_update_rate}</update_rate>
      <camera>
        <horizontal_fov>${camera_horizontal_fov}</horizontal_fov>
        <image>
          <width>${camera_image_width}</width>
          <height>${camera_image_height}</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>${camera_near_clip}</near>
          <far>${camera_far_clip}</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros2_camera.so" name="camera_face_controller">
        <frame_name>camera_optical_face</frame_name>
        <camera_name>camera_face</camera_name>
        <image_topic>/camera_face/${topic_camera_color}</image_topic>
        <camera_info_topic>/camera_face/color/camera_info</camera_info_topic>
        <depth_image_topic>/camera_face/${topic_camera_depth}</depth_image_topic>
        <depth_camera_info_topic>/camera_face/depth/camera_info</depth_camera_info_topic>
        <point_cloud_topic>/camera_face/${topic_camera_points}</point_cloud_topic>
        <min_depth>${camera_min_depth}</min_depth>
        <max_depth>${camera_max_depth}</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_chin">
    <sensor name="camera_chin_camera" type="depth">
      <update_rate>${camera_update_rate}</update_rate>
      <camera>
        <horizontal_fov>${camera_horizontal_fov}</horizontal_fov>
        <image>
          <width>${camera_image_width}</width>
          <height>${camera_image_height}</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>${camera_near_clip}</near>
          <far>${camera_far_clip}</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros2_camera.so" name="camera_chin_controller">
        <frame_name>camera_optical_chin</frame_name>
        <camera_name>camera_chin</camera_name>
        <image_topic>/camera_chin/${topic_camera_color}</image_topic>
        <camera_info_topic>/camera_chin/color/camera_info</camera_info_topic>
        <depth_image_topic>/camera_chin/${topic_camera_depth}</depth_image_topic>
        <depth_camera_info_topic>/camera_chin/depth/camera_info</depth_camera_info_topic>
        <point_cloud_topic>/camera_chin/${topic_camera_points}</point_cloud_topic>
        <min_depth>${camera_min_depth}</min_depth>
        <max_depth>${camera_max_depth}</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_left">
    <sensor name="camera_left_camera" type="depth">
      <update_rate>${camera_update_rate}</update_rate>
      <camera>
        <horizontal_fov>${camera_horizontal_fov}</horizontal_fov>
        <image>
          <width>${camera_image_width}</width>
          <height>${camera_image_height}</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>${camera_near_clip}</near>
          <far>${camera_far_clip}</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros2_camera.so" name="camera_left_controller">
        <frame_name>camera_optical_left</frame_name>
        <camera_name>camera_left</camera_name>
        <image_topic>/camera_left/${topic_camera_color}</image_topic>
        <camera_info_topic>/camera_left/color/camera_info</camera_info_topic>
        <depth_image_topic>/camera_left/${topic_camera_depth}</depth_image_topic>
        <depth_camera_info_topic>/camera_left/depth/camera_info</depth_camera_info_topic>
        <point_cloud_topic>/camera_left/${topic_camera_points}</point_cloud_topic>
        <min_depth>${camera_min_depth}</min_depth>
        <max_depth>${camera_max_depth}</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_right">
    <sensor name="camera_right_camera" type="depth">
      <update_rate>${camera_update_rate}</update_rate>
      <camera>
        <horizontal_fov>${camera_horizontal_fov}</horizontal_fov>
        <image>
          <width>${camera_image_width}</width>
          <height>${camera_image_height}</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>${camera_near_clip}</near>
          <far>${camera_far_clip}</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros2_camera.so" name="camera_right_controller">
        <frame_name>camera_optical_right</frame_name>
        <camera_name>camera_right</camera_name>
        <image_topic>/camera_right/${topic_camera_color}</image_topic>
        <camera_info_topic>/camera_right/color/camera_info</camera_info_topic>
        <depth_image_topic>/camera_right/${topic_camera_depth}</depth_image_topic>
        <depth_camera_info_topic>/camera_right/depth/camera_info</depth_camera_info_topic>
        <point_cloud_topic>/camera_right/${topic_camera_points}</point_cloud_topic>
        <min_depth>${camera_min_depth}</min_depth>
        <max_depth>${camera_max_depth}</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_rearDown">
    <sensor name="camera_rearDown_camera" type="depth">
      <update_rate>${camera_update_rate}</update_rate>
      <camera>
        <horizontal_fov>${camera_horizontal_fov}</horizontal_fov>
        <image>
          <width>${camera_image_width}</width>
          <height>${camera_image_height}</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>${camera_near_clip}</near>
          <far>${camera_far_clip}</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros2_camera.so" name="camera_rearDown_controller">
        <frame_name>camera_optical_rearDown</frame_name>
        <camera_name>camera_rearDown</camera_name>
        <image_topic>/camera_rearDown/${topic_camera_color}</image_topic>
        <camera_info_topic>/camera_rearDown/color/camera_info</camera_info_topic>
        <depth_image_topic>/camera_rearDown/${topic_camera_depth}</depth_image_topic>
        <depth_camera_info_topic>/camera_rearDown/depth/camera_info</depth_camera_info_topic>
        <point_cloud_topic>/camera_rearDown/${topic_camera_points}</point_cloud_topic>
        <min_depth>${camera_min_depth}</min_depth>
        <max_depth>${camera_max_depth}</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===================== 足端接触传感器 ===================== -->
  <gazebo reference="FR_calf">
    <sensor name="FR_foot_contact" type="contact">
      <update_rate>${foot_contact_update_rate}</update_rate>
      <plugin filename="libFootContactPlugin.so" name="FR_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>FR_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="FL_calf">
    <sensor name="FL_foot_contact" type="contact">
      <update_rate>${foot_contact_update_rate}</update_rate>
      <plugin filename="libFootContactPlugin.so" name="FL_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>FL_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="RR_calf">
    <sensor name="RR_foot_contact" type="contact">
      <update_rate>${foot_contact_update_rate}</update_rate>
      <plugin filename="libFootContactPlugin.so" name="RR_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>RR_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="RL_calf">
    <sensor name="RL_foot_contact" type="contact">
      <update_rate>${foot_contact_update_rate}</update_rate>
      <plugin filename="libFootContactPlugin.so" name="RL_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>RL_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>

  <!-- ===================== 足端力可视化插件 (ROS2) ===================== -->
  <gazebo reference="FR_foot">
    <visual>
      <plugin filename="libDrawForcePlugin.so" name="FR_drawForcePlugin">
        <topicName>FR_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>
  <gazebo reference="FL_foot">
    <visual>
      <plugin filename="libDrawForcePlugin.so" name="FL_drawForcePlugin">
        <topicName>FL_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>
  <gazebo reference="RR_foot">
    <visual>
      <plugin filename="libDrawForcePlugin.so" name="RR_drawForcePlugin">
        <topicName>RR_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>
  <gazebo reference="RL_foot">
    <visual>
      <plugin filename="libDrawForcePlugin.so" name="RL_drawForcePlugin">
        <topicName>RL_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>

  <!-- ===================== 全局物理属性配置 ===================== -->
  <gazebo reference="base">
    <material>Gazebo/Green</material>
    <turnGravityOff>false</turnGravityOff>
  </gazebo>
  <gazebo reference="trunk">
    <mu1>${trunk_mu1}</mu1>
    <mu2>${trunk_mu2}</mu2>
    <kp value="${trunk_kp}"/>
    <kd value="${trunk_kd}"/>
  </gazebo>
  <gazebo reference="imu_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Red</material>
  </gazebo>
  <gazebo reference="depthCamera_link_left">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- ===================== 腿部物理属性 ===================== -->
  <!-- 前右 FR -->
  <gazebo reference="FR_hip">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="FR_thigh">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="${leg_kp}"/>
    <kd value="${leg_kd}"/>
  </gazebo>
  <gazebo reference="FR_calf">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="FR_foot">
    <mu1>${foot_mu1}</mu1>
    <mu2>${foot_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="${foot_kp}"/>
    <kd value="${foot_kd}"/>
  </gazebo>

  <!-- 前左 FL -->
  <gazebo reference="FL_hip">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="FL_thigh">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="${leg_kp}"/>
    <kd value="${leg_kd}"/>
  </gazebo>
  <gazebo reference="FL_calf">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="FL_foot">
    <mu1>${foot_mu1}</mu1>
    <mu2>${foot_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="${foot_kp}"/>
    <kd value="${foot_kd}"/>
  </gazebo>

  <!-- 后右 RR -->
  <gazebo reference="RR_hip">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="RR_thigh">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="${leg_kp}"/>
    <kd value="${leg_kd}"/>
  </gazebo>
  <gazebo reference="RR_calf">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="RR_foot">
    <mu1>${foot_mu1}</mu1>
    <mu2>${foot_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="${foot_kp}"/>
    <kd value="${foot_kd}"/>
  </gazebo>

  <!-- 后左 RL -->
  <gazebo reference="RL_hip">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="RL_thigh">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="${leg_kp}"/>
    <kd value="${leg_kd}"/>
  </gazebo>
  <gazebo reference="RL_calf">
    <mu1>${leg_mu1}</mu1>
    <mu2>${leg_mu2}</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="RL_foot">
    <mu1>${foot_mu1}</mu1>
    <mu2>${foot_mu2}</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="${foot_kp}"/>
    <kd value="${foot_kd}"/>
  </gazebo>

  <!-- ===================== 基础连杆与关节 ===================== -->
  <!-- 调试模式 -->
  <xacro:if value="${debug_enabled}">
    <link name="world"/>
    <joint name="base_static_joint" type="fixed">
      <origin rpy="0 0 0" xyz="${debug_world_joint_position}"/>
      <parent link="world"/>
      <child link="base"/>
    </joint>
  </xacro:if>

  <!-- 根坐标系 -->
  <link name="base">
    <inertial>
      <mass value="${base_mass}"/>
      <inertia ixx="${base_ixx}" ixy="${base_ixy}" ixz="${base_ixz}" iyy="${base_iyy}" iyz="${base_iyz}" izz="${base_izz}"/>
    </inertial>
    <visual>
      <geometry><box size="0.001 0.001 0.001"/></geometry>
    </visual>
  </link>

  <!-- 基座固定关节 -->
  <joint name="floating_base" type="fixed">
    <origin rpy="0 0 0" xyz="${floating_base_position}"/>
    <parent link="base"/>
    <child link="trunk"/>
  </joint>

  <!-- 躯干连杆 -->
  <link name="trunk">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://go1_description/meshes/trunk.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="${trunk_collision_size}"/></geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="${trunk_com}"/>
      <mass value="${trunk_mass}"/>
      <inertia ixx="${trunk_ixx}" ixy="${trunk_ixy}" ixz="${trunk_ixz}" iyy="${trunk_iyy}" iyz="${trunk_iyz}" izz="${trunk_izz}"/>
    </inertial>
  </link>

  <!-- IMU 关节+连杆 -->
  <joint name="imu_joint" type="fixed">
    <parent link="trunk"/>
    <child link="imu_link"/>
    <origin rpy="0 0 0" xyz="${imu_joint_position}"/>
  </joint>
  <link name="imu_link">
    <inertial>
      <mass value="${imu_link_mass}"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual><geometry><box size="${imu_link_box_size}"/></geometry></visual>
    <collision><geometry><box size="${imu_link_box_size}"/></geometry></collision>
  </link>

  <!-- ===================== 深度相机 ===================== -->
  <!-- 面部相机 -->
  <joint name="camera_joint_face" type="fixed">
    <origin rpy="${PI} 0 0" xyz="${depth_camera_face}"/>
    <parent link="trunk"/>
    <child link="camera_face"/>
  </joint>
  <link name="camera_face">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${depth_camera_box_size}"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://go1_description/meshes/depthCamera.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="${depth_camera_mass}" />
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${depth_camera_ixx}" ixy="${depth_camera_ixy}" ixz="${depth_camera_ixz}" iyy="${depth_camera_iyy}" iyz="${depth_camera_iyz}" izz="${depth_camera_izz}" />
    </inertial>
  </link>
  <joint name="camera_optical_joint_face" type="fixed">
    <origin xyz="0 0 0" rpy="${-PI/2} 0 ${-PI/2}"/>
    <parent link="camera_face"/>
    <child link="camera_optical_face"/>
  </joint>
  <link name="camera_optical_face">
  </link>

  <!-- 下巴相机 -->
  <joint name="camera_joint_chin" type="fixed">
    <origin rpy="${PI} ${PI/2} 0" xyz="${depth_camera_chin}"/>
    <parent link="trunk"/>
    <child link="camera_chin"/>
  </joint>
  <link name="camera_chin">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${depth_camera_box_size}"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://go1_description/meshes/depthCamera.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="${depth_camera_mass}" />
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${depth_camera_ixx}" ixy="${depth_camera_ixy}" ixz="${depth_camera_ixz}" iyy="${depth_camera_iyy}" iyz="${depth_camera_iyz}" izz="${depth_camera_izz}" />
    </inertial>
  </link>
  <joint name="camera_optical_joint_chin" type="fixed">
    <origin xyz="0 0 0" rpy="${-PI/2} 0 ${-PI/2}"/>
    <parent link="camera_chin"/>
    <child link="camera_optical_chin"/>
  </joint>
  <link name="camera_optical_chin">
  </link>

  <!-- 左相机 -->
  <joint name="camera_joint_left" type="fixed">
    <origin rpy="${PI} 0.2618 ${PI/2}" xyz="${depth_camera_left}"/>
    <parent link="trunk"/>
    <child link="camera_left"/>
  </joint>
  <link name="camera_left">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${depth_camera_box_size}"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://go1_description/meshes/depthCamera.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="${depth_camera_mass}" />
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${depth_camera_ixx}" ixy="${depth_camera_ixy}" ixz="${depth_camera_ixz}" iyy="${depth_camera_iyy}" iyz="${depth_camera_iyz}" izz="${depth_camera_izz}" />
    </inertial>
  </link>
  <joint name="camera_optical_joint_left" type="fixed">
    <origin xyz="0 0 0" rpy="${-PI/2} 0 ${-PI/2}"/>
