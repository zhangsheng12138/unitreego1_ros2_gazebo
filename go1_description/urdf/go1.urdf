<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    ROS2 Compatible Go1 Robot URDF                                                | -->
<!-- |    Gazebo Harmonic + ros2_control                                               | -->
<!-- |    完整无省略版 - Unitree Go1 四足机器人                                       | -->
<!-- =================================================================================== -->
<robot name="go1">
  <!-- ===================== 基础材料定义 ===================== -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.9137 0.9137 0.8471 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>
  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- ===================== ROS2 CONTROL 核心插件 ===================== -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find go1_description)/config/robot_control.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ===================== 基座轨迹可视化插件 ===================== -->
  <gazebo>
    <plugin filename="libLinkPlot3DPlugin.so" name="3dplot">
      <frequency>10</frequency>
      <plot>
        <link>base</link>
        <pose>0 0 0 0 0 0</pose>
        <material>Gazebo/Yellow</material>
      </plot>
    </plugin>
  </gazebo>

  <!-- ===================== 外力施加插件 (ROS2) ===================== -->
  <gazebo>
    <plugin filename="libgazebo_ros_force.so" name="gazebo_ros_force">
      <body_name>trunk</body_name>
      <topic_name>/apply_force/trunk</topic_name>
      <ros2>true</ros2>
    </plugin>
  </gazebo>

  <!-- ===================== IMU 传感器 (ROS2) ===================== -->
  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>1000</update_rate>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros2_imu.so" name="imu_plugin">
        <frame_id>imu_link</frame_id>
        <topic_name>/trunk_imu</topic_name>
        <update_rate>1000.0</update_rate>
        <angular_velocity_stdev>0.0</angular_velocity_stdev>
        <linear_acceleration_stdev>0.0</linear_acceleration_stdev>
        <orientation_stdev>0.0</orientation_stdev>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>

  <!-- ===================== 深度相机 (ROS2) ===================== -->
  <gazebo reference="depthCamera_link_left">
    <sensor name="camera_link_camera" type="depth">
      <update_rate>20</update_rate>
      <camera>
        <horizontal_fov>1.047198</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>3</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros2_camera.so" name="camera_link_controller">
        <frame_name>depthCamera_link_left</frame_name>
        <camera_name>camera_link</camera_name>
        <image_topic>/camera_link/color/image_raw</image_topic>
        <camera_info_topic>/camera_link/color/camera_info</camera_info_topic>
        <depth_image_topic>/camera_link/depth/image_raw</depth_image_topic>
        <depth_camera_info_topic>/camera_link/depth/camera_info</depth_camera_info_topic>
        <point_cloud_topic>/camera_link/depth/points</point_cloud_topic>
        <min_depth>0.5</min_depth>
        <max_depth>3.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===================== 足端接触传感器 ===================== -->
  <gazebo reference="FR_calf">
    <sensor name="FR_foot_contact" type="contact">
      <update_rate>100</update_rate>
      <plugin filename="libunitreeFootContactPlugin.so" name="FR_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>FR_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="FL_calf">
    <sensor name="FL_foot_contact" type="contact">
      <update_rate>100</update_rate>
      <plugin filename="libunitreeFootContactPlugin.so" name="FL_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>FL_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="RR_calf">
    <sensor name="RR_foot_contact" type="contact">
      <update_rate>100</update_rate>
      <plugin filename="libunitreeFootContactPlugin.so" name="RR_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>RR_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="RL_calf">
    <sensor name="RL_foot_contact" type="contact">
      <update_rate>100</update_rate>
      <plugin filename="libunitreeFootContactPlugin.so" name="RL_contactPlugin">
        <ros2>true</ros2>
      </plugin>
      <contact>
        <collision>RL_foot_collision</collision>
      </contact>
    </sensor>
  </gazebo>

  <!-- ===================== 足端力可视化插件 (ROS2) ===================== -->
  <gazebo reference="FR_foot">
    <visual>
      <plugin filename="libunitreeDrawForcePlugin.so" name="FR_drawForcePlugin">
        <topicName>FR_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>
  <gazebo reference="FL_foot">
    <visual>
      <plugin filename="libunitreeDrawForcePlugin.so" name="FL_drawForcePlugin">
        <topicName>FL_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>
  <gazebo reference="RR_foot">
    <visual>
      <plugin filename="libunitreeDrawForcePlugin.so" name="RR_drawForcePlugin">
        <topicName>RR_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>
  <gazebo reference="RL_foot">
    <visual>
      <plugin filename="libunitreeDrawForcePlugin.so" name="RL_drawForcePlugin">
        <topicName>RL_foot_contact</topicName>
      </plugin>
    </visual>
  </gazebo>

  <!-- ===================== 全局物理属性配置 ===================== -->
  <gazebo reference="base">
    <material>Gazebo/Green</material>
    <turnGravityOff>false</turnGravityOff>
  </gazebo>
  <gazebo reference="trunk">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>
  <gazebo reference="imu_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Red</material>
  </gazebo>
  <gazebo reference="depthCamera_link_left">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- ===================== 腿部物理属性 ===================== -->
  <!-- 前右 FR -->
  <gazebo reference="FR_hip">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="FR_thigh">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>
  <gazebo reference="FR_calf">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="FR_foot">
    <mu1>0.6</mu1>
    <mu2>0.6</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>

  <!-- 前左 FL -->
  <gazebo reference="FL_hip">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="FL_thigh">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>
  <gazebo reference="FL_calf">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="FL_foot">
    <mu1>0.6</mu1>
    <mu2>0.6</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>

  <!-- 后右 RR -->
  <gazebo reference="RR_hip">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="RR_thigh">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>
  <gazebo reference="RR_calf">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="RR_foot">
    <mu1>0.6</mu1>
    <mu2>0.6</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>

  <!-- 后左 RL -->
  <gazebo reference="RL_hip">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="RL_thigh">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/DarkGrey</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>
  <gazebo reference="RL_calf">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>true</self_collide>
  </gazebo>
  <gazebo reference="RL_foot">
    <mu1>0.6</mu1>
    <mu2>0.6</mu2>
    <self_collide>true</self_collide>
    <material>Gazebo/Orange</material>
    <kp value="1000000.0"/>
    <kd value="1.0"/>
  </gazebo>

  <!-- ===================== 基础连杆与关节 ===================== -->
  <!-- 根坐标系 -->
  <link name="base">
    <inertial>
      <mass value="0.0001"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><box size="0.001 0.001 0.001"/></geometry>
    </visual>
  </link>

  <!-- 基座固定关节 -->
  <joint name="floating_base" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base"/>
    <child link="trunk"/>
  </joint>

  <!-- 躯干连杆 -->
  <link name="trunk">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://go1_description/meshes/trunk.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.3762 0.0935 0.114"/></geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0223 0.002 -0.0005"/>
      <mass value="5.204"/>
      <inertia ixx="0.0168128557" ixy="-0.0002296769" ixz="-0.0002945293" iyy="0.063009565" iyz="-4.18731e-05" izz="0.0716547275"/>
    </inertial>
  </link>

  <!-- IMU 关节+连杆 -->
  <joint name="imu_joint" type="fixed">
    <parent link="trunk"/>
    <child link="imu_link"/>
    <origin rpy="0 0 0" xyz="-0.01592 -0.06659 -0.00617"/>
  </joint>
  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual><geometry><box size="0.01 0.01 0.01"/></geometry></visual>
    <collision><geometry><box size="0.01 0.01 0.01"/></geometry></collision>
  </link>

  <!-- 深度相机 关节+连杆 -->
  <joint name="depthCamera_joint" type="fixed">
    <parent link="trunk"/>
    <child link="depthCamera_link_left"/>
    <origin rpy="0 0 0" xyz="0.15 0.05 0.05"/>
  </joint>
  <link name="depthCamera_link_left">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual><geometry><box size="0.05 0.05 0.05"/></geometry></visual>
    <collision><geometry><box size="0.05 0.05 0.05"/></geometry></collision>
  </link>

  <!-- ===================== 前右腿 FR (3个旋转关节) ===================== -->
  <joint name="FR_hip_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.1881 -0.04675 0"/>
    <parent link="trunk"/>
    <child link="FR_hip"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-0.863" upper="0.863" velocity="30.1"/>
  </joint>
  <link name="FR_hip">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual><geometry><cylinder length="0.05" radius="0.02"/></geometry></visual>
    <collision><geometry><cylinder length="0.05" radius="0.02"/></geometry></collision>
  </link>

  <joint name="FR_thigh_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 -0.04675 0"/>
    <parent link="FR_hip"/>
    <child link="FR_thigh"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-1.047" upper="4.0" velocity="30.1"/>
  </joint>
  <link name="FR_thigh">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.015"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.015"/></geometry></collision>
  </link>

  <joint name="FR_calf_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="FR_thigh"/>
    <child link="FR_calf"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-2.6" upper="-0.8" velocity="30.1"/>
  </joint>
  <link name="FR_calf">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.01"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.01"/></geometry></collision>
  </link>

  <joint name="FR_foot_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="FR_calf"/>
    <child link="FR_foot"/>
  </joint>
  <link name="FR_foot">
    <collision name="FR_foot_collision">
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <visual><geometry><sphere radius="0.02"/></geometry></visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== 前左腿 FL (3个旋转关节) ===================== -->
  <joint name="FL_hip_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.1881 0.04675 0"/>
    <parent link="trunk"/>
    <child link="FL_hip"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-0.863" upper="0.863" velocity="30.1"/>
  </joint>
  <link name="FL_hip">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual><geometry><cylinder length="0.05" radius="0.02"/></geometry></visual>
    <collision><geometry><cylinder length="0.05" radius="0.02"/></geometry></collision>
  </link>

  <joint name="FL_thigh_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 0.04675 0"/>
    <parent link="FL_hip"/>
    <child link="FL_thigh"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-1.047" upper="4.0" velocity="30.1"/>
  </joint>
  <link name="FL_thigh">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.015"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.015"/></geometry></collision>
  </link>

  <joint name="FL_calf_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="FL_thigh"/>
    <child link="FL_calf"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-2.6" upper="-0.8" velocity="30.1"/>
  </joint>
  <link name="FL_calf">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.01"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.01"/></geometry></collision>
  </link>

  <joint name="FL_foot_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="FL_calf"/>
    <child link="FL_foot"/>
  </joint>
  <link name="FL_foot">
    <collision name="FL_foot_collision">
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <visual><geometry><sphere radius="0.02"/></geometry></visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== 后右腿 RR (3个旋转关节) ===================== -->
  <joint name="RR_hip_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.1881 -0.04675 0"/>
    <parent link="trunk"/>
    <child link="RR_hip"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-0.863" upper="0.863" velocity="30.1"/>
  </joint>
  <link name="RR_hip">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual><geometry><cylinder length="0.05" radius="0.02"/></geometry></visual>
    <collision><geometry><cylinder length="0.05" radius="0.02"/></geometry></collision>
  </link>

  <joint name="RR_thigh_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 -0.04675 0"/>
    <parent link="RR_hip"/>
    <child link="RR_thigh"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-1.047" upper="4.0" velocity="30.1"/>
  </joint>
  <link name="RR_thigh">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.015"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.015"/></geometry></collision>
  </link>

  <joint name="RR_calf_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="RR_thigh"/>
    <child link="RR_calf"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-2.6" upper="-0.8" velocity="30.1"/>
  </joint>
  <link name="RR_calf">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.01"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.01"/></geometry></collision>
  </link>

  <joint name="RR_foot_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="RR_calf"/>
    <child link="RR_foot"/>
  </joint>
  <link name="RR_foot">
    <collision name="RR_foot_collision">
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <visual><geometry><sphere radius="0.02"/></geometry></visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== 后左腿 RL (3个旋转关节) ===================== -->
  <joint name="RL_hip_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.1881 0.04675 0"/>
    <parent link="trunk"/>
    <child link="RL_hip"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-0.863" upper="0.863" velocity="30.1"/>
  </joint>
  <link name="RL_hip">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual><geometry><cylinder length="0.05" radius="0.02"/></geometry></visual>
    <collision><geometry><cylinder length="0.05" radius="0.02"/></geometry></collision>
  </link>

  <joint name="RL_thigh_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 0.04675 0"/>
    <parent link="RL_hip"/>
    <child link="RL_thigh"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-1.047" upper="4.0" velocity="30.1"/>
  </joint>
  <link name="RL_thigh">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.015"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.015"/></geometry></collision>
  </link>

  <joint name="RL_calf_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="RL_thigh"/>
    <child link="RL_calf"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
    <limit effort="23.7" lower="-2.6" upper="-0.8" velocity="30.1"/>
  </joint>
  <link name="RL_calf">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual><geometry><cylinder length="0.2" radius="0.01"/></geometry></visual>
    <collision><geometry><cylinder length="0.2" radius="0.01"/></geometry></collision>
  </link>

  <joint name="RL_foot_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 -0.2"/>
    <parent link="RL_calf"/>
    <child link="RL_foot"/>
  </joint>
  <link name="RL_foot">
    <collision name="RL_foot_collision">
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <visual><geometry><sphere radius="0.02"/></geometry></visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== ros2_control 传动定义 (必选！) ===================== -->
  <!-- 为12个旋转关节添加力矩传动接口 -->
  <transmission name="FR_hip_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="FR_hip_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="FR_hip_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="FR_thigh_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="FR_thigh_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="FR_thigh_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="FR_calf_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="FR_calf_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="FR_calf_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="FL_hip_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="FL_hip_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="FL_hip_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="FL_thigh_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="FL_thigh_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="FL_thigh_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="FL_calf_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="FL_calf_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="FL_calf_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="RR_hip_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="RR_hip_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="RR_hip_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="RR_thigh_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="RR_thigh_joint">
      <hardwareInterface>hardware_interface/effort</hardwareInterface>
    </joint>
    <actuator name="RR_thigh_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
