#!/usr/bin/env python3
"""
检查Gazebo是否成功加载世界文件的脚本

该脚本会等待Gazebo启动并加载世界文件，然后通知launch文件继续加载机器人模型
"""

import argparse
import rclpy
from rclpy.node import Node
from rclpy.utilities import remove_ros_args
from gazebo_msgs.srv import GetWorldProperties
import sys
import time


class GazeboReadyChecker(Node):
    """
    检查Gazebo是否准备就绪的节点
    """
    
    def __init__(self, timeout=60):
        """
        初始化节点
        
        Args:
            timeout: 超时时间（秒）
        """
        super().__init__('check_gazebo_ready')
        self.timeout = timeout
        self.start_time = time.time()
        self.get_logger().info(f"开始检查Gazebo是否准备就绪，超时时间: {timeout}秒")
        
        # 创建服务客户端
        self.world_properties_client = self.create_client(
            GetWorldProperties, '/gazebo/get_world_properties')
        
        # 等待服务可用
        while not self.world_properties_client.wait_for_service(timeout_sec=1.0):
            if time.time() - self.start_time > self.timeout:
                self.get_logger().error("Gazebo服务启动超时")
                rclpy.shutdown()
                exit(1)
            self.get_logger().info("等待Gazebo服务可用...")
        
        # 检查世界是否加载成功
        self.check_world_loaded()
    
    def check_world_loaded(self):
        """
        检查世界是否加载成功
        """
        while time.time() - self.start_time < self.timeout:
            # 创建请求
            request = GetWorldProperties.Request()
            
            # 发送请求
            future = self.world_properties_client.call_async(request)
            
            # 等待响应
            rclpy.spin_until_future_complete(self, future)
            
            if future.result():
                world_name = future.result().world_name
                self.get_logger().info(f"Gazebo世界加载成功: {world_name}")
                self.get_logger().info("Gazebo准备就绪，开始加载机器人模型")
                return
            else:
                self.get_logger().warn("无法获取世界属性，重试...")
                time.sleep(1.0)
        
        # 超时
        self.get_logger().error("检查Gazebo世界加载超时")
        rclpy.shutdown()
        exit(1)


def main():
    """
    主函数
    """
    # 移除ROS2的命令行参数
    args = remove_ros_args(sys.argv)
    
    # 解析命令行参数
    parser = argparse.ArgumentParser(description='检查Gazebo是否准备就绪')
    parser.add_argument('--timeout', type=int, default=60, help='超时时间（秒）')
    parsed_args = parser.parse_args(args[1:])  # 跳过第一个参数（程序名称）
    
    # 初始化ROS
    rclpy.init()
    
    # 创建检查器
    checker = GazeboReadyChecker(timeout=parsed_args.timeout)
    
    # 关闭节点
    checker.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
